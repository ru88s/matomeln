{
  "name": "matomeln",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "./scripts/dev-setup.sh && next dev --turbopack",
    "build": "./scripts/build-clean.sh && CF_PAGES=true next build --turbopack && ./scripts/post-build.sh",
    "build:local": "./scripts/dev-setup.sh && next build --turbopack",
    "start": "next start",
    "pages:dev": "npx wrangler pages dev --compatibility-date=2026-05-08 --compatibility-flag=nodejs_compat",
    "pages:deploy": "npm run build && ./scripts/verify-build.sh && npx wrangler pages deploy"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@heroui/react": "^3.2.2",
    "@heroui/styles": "^3.2.2",
    "encoding-japanese": "^2.2.0",
    "next": "15.5.18",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hot-toast": "^2.6.0",
    "react-tweet": "^3.3.0",
    "wsse": "^6.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260514.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/encoding-japanese": "^2.2.1",
    "@types/node": "^20.19.41",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19",
    "tailwindcss": "^4.3.0",
    "typescript": "^5",
    "wrangler": "^4.91.0"
  }
}
